#!/bin/sh
set -e

# lazymem requires Bun runtime
if ! command -v bun >/dev/null 2>&1; then
  echo "lazymem requires Bun. Install it:" >&2
  echo "  curl -fsSL https://bun.sh/install | bash" >&2
  exit 1
fi

# macOS only
if [ "$(uname -s)" != "Darwin" ]; then
  echo "lazymem only supports macOS (uses vm_stat, sysctl)" >&2
  exit 1
fi

# Resolve symlinks to find the real package directory
# macOS readlink lacks -f, so we resolve manually
resolve_link() {
  local file="$1"
  while [ -L "$file" ]; do
    local dir="$(cd "$(dirname "$file")" && pwd)"
    file="$(readlink "$file")"
    case "$file" in
      /*) ;;
      *) file="$dir/$file" ;;
    esac
  done
  echo "$file"
}

SCRIPT="$(resolve_link "$0")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
PACKAGE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Find preload script: nested node_modules (npm) or hoisted (bun global)
PRELOAD="$PACKAGE_DIR/node_modules/@opentui/solid/scripts/preload.ts"
if [ ! -f "$PRELOAD" ]; then
  # bun hoists deps to the global node_modules root
  PRELOAD="$(cd "$PACKAGE_DIR/.." && pwd)/@opentui/solid/scripts/preload.ts"
fi
if [ ! -f "$PRELOAD" ]; then
  echo "lazymem: could not find @opentui/solid preload script" >&2
  echo "Try reinstalling: bun install -g lazymem" >&2
  exit 1
fi

exec bun --preload="$PRELOAD" "$PACKAGE_DIR/src/index.tsx" "$@"
