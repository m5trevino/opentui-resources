{
  "name": "@wyattjoh/opentui-testing",
  "version": "1.0.1",
  "description": "Snapshot-friendly testing helpers for OpenTUI React apps under bun test",
  "keywords": [
    "opentui",
    "testing",
    "snapshot",
    "tui",
    "react",
    "bun",
    "terminal"
  ],
  "author": "Wyatt Johnson <wyattjoh@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/wyattjoh/opentui-testing#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyattjoh/opentui-testing.git"
  },
  "bugs": {
    "url": "https://github.com/wyattjoh/opentui-testing/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.2.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "test": "bun test",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build": "bun run clean && tsc -p tsconfig.build.json",
    "prepack": "bun run build"
  },
  "peerDependencies": {
    "@opentui/core": "^0.2.9",
    "@opentui/react": "^0.2.9",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@opentui/core": "0.2.9",
    "@opentui/react": "0.2.9",
    "@types/bun": "latest",
    "@types/react": "19.2.14",
    "react": "19.2.6",
    "typescript": "^6.0.3"
  }
}
