{
  "schemaVersion": 1,
  "name": "{{scheme-name}}",
  "slug": "{{scheme-slug}}",
  "system": "{{scheme-system}}",
  "author": "{{scheme-author}}",
  "palette": {
    "base00": "#{{base00-hex}}",
    "base01": "#{{base01-hex}}",
    "base02": "#{{base02-hex}}",
    "base03": "#{{base03-hex}}",
    "base04": "#{{base04-hex}}",
    "base05": "#{{base05-hex}}",
    "base06": "#{{base06-hex}}",
    "base07": "#{{base07-hex}}",
    "base08": "#{{base08-hex}}",
    "base09": "#{{base09-hex}}",
    "base0A": "#{{base0A-hex}}",
    "base0B": "#{{base0B-hex}}",
    "base0C": "#{{base0C-hex}}",
    "base0D": "#{{base0D-hex}}",
    "base0E": "#{{base0E-hex}}",
    "base0F": "#{{base0F-hex}}"
  },
  "tokens": {
    "background": "#{{base00-hex}}",
    "surface": "#{{base01-hex}}",
    "surfaceAlt": "#{{base02-hex}}",
    "surfaceRaised": "#{{base02-hex}}",
    "border": "#{{base03-hex}}",
    "borderFocused": "#{{base0D-hex}}",
    "text": "#{{base05-hex}}",
    "textMuted": "#{{base04-hex}}",
    "textSubtle": "#{{base03-hex}}",
    "textInverse": "#{{base00-hex}}",
    "accent": "#{{base0D-hex}}",
    "accentText": "#{{base00-hex}}",
    "success": "#{{base0B-hex}}",
    "warning": "#{{base0A-hex}}",
    "danger": "#{{base08-hex}}",
    "info": "#{{base0C-hex}}",
    "selectionBg": "#{{base02-hex}}",
    "selectionFg": "#{{base05-hex}}",
    "cursor": "#{{base0D-hex}}",
    "scrollbarTrack": "#{{base01-hex}}",
    "scrollbarThumb": "#{{base03-hex}}"
  },
  "components": {
    "renderer": {
      "backgroundColor": "#{{base00-hex}}",
      "cursorColor": "#{{base0D-hex}}"
    },
    "box": {
      "backgroundColor": "#{{base00-hex}}",
      "borderColor": "#{{base03-hex}}",
      "focusedBorderColor": "#{{base0D-hex}}"
    },
    "text": {
      "fg": "#{{base05-hex}}",
      "bg": "#{{base00-hex}}",
      "selectionBg": "#{{base02-hex}}",
      "selectionFg": "#{{base05-hex}}"
    },
    "input": {
      "backgroundColor": "#{{base01-hex}}",
      "textColor": "#{{base05-hex}}",
      "focusedBackgroundColor": "#{{base02-hex}}",
      "focusedTextColor": "#{{base05-hex}}",
      "placeholderColor": "#{{base04-hex}}",
      "selectionBg": "#{{base03-hex}}",
      "selectionFg": "#{{base05-hex}}",
      "cursorColor": "#{{base0D-hex}}"
    },
    "textarea": {
      "backgroundColor": "#{{base01-hex}}",
      "textColor": "#{{base05-hex}}",
      "focusedBackgroundColor": "#{{base02-hex}}",
      "focusedTextColor": "#{{base05-hex}}",
      "placeholderColor": "#{{base04-hex}}",
      "selectionBg": "#{{base03-hex}}",
      "selectionFg": "#{{base05-hex}}",
      "cursorColor": "#{{base0D-hex}}"
    },
    "select": {
      "backgroundColor": "#{{base00-hex}}",
      "textColor": "#{{base05-hex}}",
      "focusedBackgroundColor": "#{{base01-hex}}",
      "focusedTextColor": "#{{base05-hex}}",
      "selectedBackgroundColor": "#{{base0D-hex}}",
      "selectedTextColor": "#{{base00-hex}}",
      "descriptionColor": "#{{base04-hex}}",
      "selectedDescriptionColor": "#{{base00-hex}}"
    },
    "tabSelect": {
      "backgroundColor": "#{{base00-hex}}",
      "textColor": "#{{base04-hex}}",
      "focusedBackgroundColor": "#{{base01-hex}}",
      "focusedTextColor": "#{{base05-hex}}",
      "selectedBackgroundColor": "#{{base0D-hex}}",
      "selectedTextColor": "#{{base00-hex}}",
      "selectedDescriptionColor": "#{{base00-hex}}"
    },
    "scrollbar": {
      "trackOptions": {
        "backgroundColor": "#{{base01-hex}}",
        "foregroundColor": "#{{base03-hex}}"
      },
      "arrowOptions": {
        "foregroundColor": "#{{base04-hex}}",
        "backgroundColor": "#{{base01-hex}}"
      }
    },
    "markdown": {
      "fg": "#{{base05-hex}}",
      "bg": "#{{base00-hex}}",
      "borderColor": "#{{base03-hex}}"
    },
    "code": {
      "fg": "#{{base05-hex}}",
      "bg": "#{{base00-hex}}",
      "selectionBg": "#{{base02-hex}}",
      "selectionFg": "#{{base05-hex}}"
    }
  }
}
