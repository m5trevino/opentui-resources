{
  "name": "tinty-opentui",
  "version": "0.1.0",
  "description": "Tinted Theming and tinty integration helpers for OpenTUI apps.",
  "type": "module",
  "license": "MIT",
  "author": "Mike Bannister",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/possibilities/tinted-opentui.git"
  },
  "bugs": {
    "url": "https://github.com/possibilities/tinted-opentui/issues"
  },
  "homepage": "https://github.com/possibilities/tinted-opentui#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "templates",
    "themes",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "generate": "bash scripts/generate-themes.sh",
    "validate:themes": "find themes -name '*.json' -print0 | xargs -0 jq empty"
  },
  "keywords": [
    "opentui",
    "tinty",
    "tinted-theming",
    "base16",
    "base24",
    "terminal",
    "tui"
  ],
  "peerDependencies": {
    "@opentui/core": ">=0.1.102 <1",
    "@opentui/react": ">=0.1.102 <1",
    "react": ">=18 <20"
  },
  "peerDependenciesMeta": {
    "@opentui/react": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentui/core": "0.1.102",
    "@opentui/react": "0.1.102",
    "@types/bun": "^1.3.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "react": "^19.2.0",
    "typescript": "^5.9.3"
  }
}
