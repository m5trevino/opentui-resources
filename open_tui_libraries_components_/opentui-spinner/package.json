{
  "name": "opentui-spinner",
  "version": "0.0.6",
  "description": "A small & opinionated spinner library",
  "author": "Matt Simpson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/msmps/opentui-spinner.git"
  },
  "type": "module",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.mts",
        "default": "./dist/react.mjs"
      }
    },
    "./solid": {
      "import": {
        "types": "./dist/solid.d.mts",
        "default": "./dist/solid.mjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "opentui",
    "spinner",
    "cli",
    "terminal",
    "console",
    "tui"
  ],
  "scripts": {
    "build": "tsdown",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "test": "bun run test:core && bun run test:react && bun run test:solid && bun run test:package",
    "test:core": "bun test tests/core",
    "test:react": "bun test tests/react",
    "test:solid": "bun test --preload @opentui/solid/preload tests/solid",
    "test:package": "bun run build && bun test tests/package",
    "test:coverage": "bun test --coverage tests/core tests/react && bun test --coverage --preload @opentui/solid/preload tests/solid",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tests/solid/tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@opentui/core": "^0.3.4",
    "@opentui/react": "^0.3.4",
    "@opentui/solid": "^0.3.4",
    "@types/bun": "latest",
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "solid-js": "1.9.12",
    "tsdown": "^0.16.0"
  },
  "peerDependencies": {
    "@opentui/core": "^0.3.4",
    "@opentui/react": "^0.3.4",
    "@opentui/solid": "^0.3.4",
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "@opentui/react": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "dependencies": {
    "cli-spinners": "^3.3.0"
  }
}
