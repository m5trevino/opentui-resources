    "@tooee/shell": "workspace:*",
    "@tooee/themes": "workspace:*",
    "marked": "^17.0.4"
  },
  "devDependencies": {
    "@opentui/core": "^0.2.15",
    "@opentui/react": "^0.2.15",
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@opentui/core": "^0.2.15",
    "@opentui/react": "^0.2.15",
    "react": "^18.0.0 || ^19.0.0"
  }
