{
  "name": "anscribe-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter '@anscribe/*' build",
    "test": "bun run --filter '@anscribe/*' test",
    "test:integration": "bun run --filter '@anscribe/opentui' test:integration",
    "lint": "oxlint packages examples apps --disable-nested-config",
    "format": "oxfmt --write \"**/*.{ts,json}\" \"!.repos/**\" \"!**/dist/**\"",
    "format:check": "oxfmt --check \"**/*.{ts,json}\" \"!.repos/**\" \"!**/dist/**\"",
    "typecheck": "tsc --noEmit",
    "typecheck:tsgo": "tsgo --noEmit",
    "tsgo:patch": "effect-tsgo patch",
    "tsgo:unpatch": "effect-tsgo unpatch",
    "mcp": "bun run packages/mcp/bin/anscribe-mcp.ts",
    "sync:meta": "bun run scripts/sync-package-meta.ts",
    "check:meta": "bun run scripts/sync-package-meta.ts --check",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run build && bun run test && bun run check:meta",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm --filter './packages/*' build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "^2.31.0",
    "@effect/tsgo": "^0.5.2",
    "@effect/vitest": "^4.0.0-beta.65",
    "@opentui/core": "^0.2.8",
    "@opentui/react": "0.2.8",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260510.1",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "react": "^19.2.0",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.0",
    "unrun": "^0.3.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.29.3"
}
